# Augustus Corp — Production Environment Template
# Copy this file to .env and fill in real values before deploying.

# REQUIRED — generate with: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=CHANGE-THIS-TO-A-LONG-RANDOM-STRING

# Set to False in production
DEBUG=False

# Comma-separated list of allowed domains
ALLOWED_HOSTS=augustustransport.com,www.augustustransport.com

# Optional — PostgreSQL connection string (leave blank to use SQLite)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Optional — set to False if your host handles HTTPS termination (e.g. Heroku, Nginx)
SECURE_SSL_REDIRECT=True

# Required in production — comma-separated list of trusted origins for CSRF (include https://)
# e.g. https://augustustransport.com,https://www.augststransport.com
CSRF_TRUSTED_ORIGINS=https://augststransport.com,https://www.augststransport.com

# Optional — Cloudinary URL for media file storage (required on Heroku/Railway — no persistent disk)
# Get from cloudinary.com dashboard → Environment variable
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Optional — Google Maps API key for the cost calculator
GOOGLE_MAPS_API_KEY=

# Logging level: DEBUG, INFO, WARNING, ERROR
DJANGO_LOG_LEVEL=WARNING
